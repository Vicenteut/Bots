# Token del bot de Telegram (de @BotFather)
ARMANDITO_BOT_TOKEN=tu_token_aqui

# Tu Telegram ID (para briefings automaticos)
ARMANDITO_OWNER_ID=tu_telegram_id

# Anthropic API key (para AI fallback)
ANTHROPIC_API_KEY=tu_api_key

# Modelo AI (opcional, default: claude-haiku-4-5-20251001)
# ARMANDITO_MODEL=claude-haiku-4-5-20251001

# Hora del briefing matutino (0-23, default: 7)
# BRIEFING_HOUR=7

# Hora del wrap-up nocturno (0-23, default: 21)
# WRAPUP_HOUR=21

# Ruta de la base de datos (opcional)
# ARMANDITO_DB=/root/armandito/armandito.db
