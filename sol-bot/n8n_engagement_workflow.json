    },
    {
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Split into Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 300],
      "parameters": {
        "jsCode": "// HTTP response is an array — split into individual n8n items\nconst tweets = $input.first().json;\nif (!Array.isArray(tweets) || tweets.length === 0) {\n  return [{ json: { _empty: true } }];\n}\nreturn tweets.map(t => ({ json: t }));"
      }
    },
    {
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Split Tweets",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [860, 300],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "name": "Fetch X Metrics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 300],
      "continueOnFail": true,
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.twitter.com/2/tweets/' + $json.tweet_id + '?tweet.fields=public_metrics' }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "1",
          "name": "X Bearer Token"
        }
      }
    },
    {
      "id": "a1b2c3d4-0006-0006-0006-000000000006",
      "name": "Extract Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 300],
      "parameters": {
        "jsCode": "// Recover tweet_id and text_preview from the batch loop\nlet batchItem;\ntry { batchItem = $('Split Tweets').item.json; } catch(e) { batchItem = {}; }\n\nconst tweet_id = batchItem.tweet_id || '';\nconst text_preview = batchItem.text_preview || '';\n\nif (!tweet_id) return [{ json: { _skip: true } }];\n\n// Extract metrics from X API v2 response\nconst metrics = ($input.first().json?.data?.public_metrics) || {};\n\nreturn [{\n  json: {\n    tweet_id,\n    text_preview,\n    like_count:       parseInt(metrics.like_count       || 0, 10),\n    retweet_count:    parseInt(metrics.retweet_count    || 0, 10),\n    reply_count:      parseInt(metrics.reply_count      || 0, 10),\n    impression_count: parseInt(metrics.impression_count || 0, 10)\n  }\n}];"
      }
    },
    {
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Update Engagement",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1520, 300],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8502/api/n8n/update-engagement",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Basic c29sOnNvbHBhc3MxMjM="
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ tweet_id: $json.tweet_id, views: $json.impression_count, likes: $json.like_count, retweets: $json.retweet_count, replies: $json.reply_count }) }}",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0008-0008-0008-000000000008",
      "name": "Check Traction",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1740, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-views-100",
              "leftValue": "={{ $json.impression_count }}",
              "rightValue": 100,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
