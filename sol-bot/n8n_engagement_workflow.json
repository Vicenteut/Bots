        "url": "https://api.telegram.org/bot8603788822:AAHkhXtvyFBqYSA-hglE0aXr_0rAZhFaWxM/sendMessage",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ chat_id: 6054558214, text: '📈 Post gaining traction: ' + $json.impression_count + ' views\\n' + $json.text_preview + '\\nhttps://x.com/inequaliti/status/' + $json.tweet_id, parse_mode: 'HTML' }) }}",
        "options": {}
      }
    },
