# Sol Bot Dashboard — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Auth ──────────────────────────────────────────────────────────────
# SHA-256 hash of the dashboard password (NOT the plaintext password)
# Generate: python3 -c "import hashlib; print(hashlib.sha256(b'YOUR_PASSWORD').hexdigest())"
DASHBOARD_PASSWORD_HASH=change_me_to_sha256_hash

# Session expiry in minutes (60 = 1 hour, 0 = never expire)
DASHBOARD_SESSION_TTL_MIN=60

# Max failed auth attempts before lockout
DASHBOARD_MAX_AUTH_ATTEMPTS=5

# ── Paths (optional — defaults work for standard VPS deploy) ──────────
# SOL_BASE_DIR=/root/x-bot/sol-bot
# SOL_LOG_DIR=/root/x-bot/logs

# ── Behavior ──────────────────────────────────────────────────────────
# Auto-refresh interval in seconds
SOL_REFRESH_INTERVAL=30

# Comma-separated list of systemd services to monitor
SOL_MONITORED_SERVICES=xbot-monitor
